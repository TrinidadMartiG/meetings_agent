# From https://console.cloud.google.com → APIs & Services → Credentials
# Client ID looks like: 123456789-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# Client Secret looks like: GOCSPX-xxxxx (NOT an AIzaSy... key)
# If you have an AIzaSy... key, that belongs in GEMINI_API_KEY below
GOOGLE_CLIENT_SECRET=

# ─── Gemini API Key ──────────────────────────────────────────────────────────
# From https://aistudio.google.com/app/apikey
# Looks like: AIzaSy... (if the value above is actually this key, paste it here)
GEMINI_API_KEY=your_gemini_api_key_here

# Security secrets (generate with: openssl rand -hex 32)
JWT_SECRET=change_this_to_a_random_secret
NEXTAUTH_SECRET=change_this_to_another_random_secret
